@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Sign Up";
}

<style>
    :root {
        --bg-dark: #0f172a;
        --panel: #1e293b;
        --muted: #94a3b8;
        --text: #f8fafc;
        --accent: #6366f1;
        --accent-hover: #4f46e5;
    }

    body {
        background: var(--bg-dark);
        color: var(--text);
        font-family: 'Inter', system-ui, sans-serif;
    }

    .auth-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .auth-card {
        width: 100%;
        max-width: 440px;
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .auth-header h1 {
        font-size: 2rem;
        font-weight: 800;
        background: linear-gradient(135deg, #818cf8, #c084fc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 0.5rem;
    }

    .auth-header p {
        color: var(--muted);
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-group label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--muted);
    }

    .form-control {
        width: 100%;
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
        color: white;
        transition: all 0.2s;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }

    .btn-primary {
        width: 100%;
        background: var(--accent);
        color: white;
        border: none;
        border-radius: 0.75rem;
        padding: 0.875rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 1rem;
    }

    .btn-primary:hover {
        background: var(--accent-hover);
    }

    .auth-footer {
        text-align: center;
        margin-top: 2rem;
        color: var(--muted);
        font-size: 0.875rem;
    }

    .auth-footer a {
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
    }

    .success-msg, .error-msg {
        padding: 0.75rem;
        border-radius: 0.75rem;
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
        display: none;
    }

    .error-msg {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #fca5a5;
    }

    .success-msg {
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: #6ee7b7;
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Create Account</h1>
            <p>Join the Movie Ranking System today</p>
        </div>

        <div id="errorBox" class="error-msg"></div>
        <div id="successBox" class="success-msg"></div>

        <form id="signupForm">
            <div class="form-group">
                <label>Username</label>
                <input type="text" id="username" class="form-control" placeholder="john_doe" required>
            </div>
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" id="email" class="form-control" placeholder="john@example.com" required>
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" id="password" class="form-control" placeholder="••••••••" required>
            </div>
            <button type="submit" class="btn-primary">Sign Up</button>
        </form>

        <div class="auth-footer">
            Already have an account? <a href="/login">Sign In</a>
        </div>
    </div>
</div>

<script>
    document.getElementById('signupForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const errorBox = document.getElementById('errorBox');
        const successBox = document.getElementById('successBox');
        errorBox.style.display = 'none';
        successBox.style.display = 'none';

        const username = document.getElementById('username').value;
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;

        try {
            const response = await fetch('/api/account/signup', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, email, password })
            });

            if (response.ok) {
                successBox.innerText = 'Account created! Redirecting to login...';
                successBox.style.display = 'block';
                setTimeout(() => window.location.href = '/login', 2000);
            } else {
                const err = await response.json();
                errorBox.innerText = err.message || 'Signup failed';
                errorBox.style.display = 'block';
            }
        } catch (error) {
            errorBox.innerText = 'Something went wrong. Please try again.';
            errorBox.style.display = 'block';
        }
    });
</script>
